# Large data files (keep on HPC storage)
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.sam
*.bam
*.bai
*.fasta
*.fa
*.fna
*.gff
*.gff3
*.gtf

# Container files (stored on HPC)
*.sif
*.img

# SLURM output files
slurm-*.out
slurm-*.err
*.o[0-9]*
*.e[0-9]*

# Results files that are too large for git
results/*/*.bam
results/*/*.sam
results/*/*.fastq*
results/*/*.fasta
results/*/*.fa

# But keep small result files
!results/*/*.txt
!results/*/*.tsv
!results/*/*.csv
!results/*/*.md
!results/*/*.html
!results/*/*.png
!results/*/*.jpg
!results/*/*.pdf
!results/*/*.bed
!results/*/.gitkeep

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Log files
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
