HiSat2
```bash
cat > /fs/scratch/PAS3260/Fiona/RNAseqforteamproject/hisat2index/hisat2index.sh << 'EOF'
#!/bin/bash
#SBATCH --job-name=hisat2_align
#SBATCH --account=PAS3260
#SBATCH --time=01:30:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=24G
#SBATCH --array=1-6
#SBATCH --output=/fs/scratch/PAS3260/Fiona/RNAseqforteamproject/logs/%x_%j.out

set -euo pipefail

TUTORIAL=/fs/scratch/PAS3260/Fiona/RNAseqforteamproject
HISAT2_SIF=/fs/scratch/PAS3260/Jonathan/Annotation/containers/hisat2_2.2.2.sif
SAM_SIF=/fs/scratch/PAS3260/Jonathan/Peltaster/containers/samtools_1.23.1.sif
INDEX=/fs/scratch/PAS3260/Fiona/RNAseqforteamproject/hisat2index/index
TRIMDIR=/fs/scratch/PAS3260/Fiona/RNAseqforteamproject/reads
OUTDIR=/fs/scratch/PAS3260/Fiona/RNAseqforteamproject/aligned

SAMPLES=(rnaseq_wt_rep1 rnaseq_wt_rep2 rnaseq_wt_rep3 \
         rnaseq_mut_rep1 rnaseq_mut_rep2 rnaseq_mut_rep3)
SAMPLE=${SAMPLES[$((SLURM_ARRAY_TASK_ID - 1))]}

echo "[$(date)] Aligning: ${SAMPLE}"

# Align → SAM
apptainer exec --bind ${TUTORIAL},/fs/scratch/PAS3260/Jonathan ${HISAT2_SIF} \
    hisat2 \
        -p 8 \
        --dta \
        -x ${INDEX} \
        -1 ${TRIMDIR}/${SAMPLE}_R1_trimmed.fastq.gz \
        -2 ${TRIMDIR}/${SAMPLE}_R2_trimmed.fastq.gz \
        --rg-id ${SAMPLE} \
        --rg "SM:${SAMPLE}" \
        --rg "PL:ILLUMINA" \
        -S ${OUTDIR}/${SAMPLE}.sam \
        2>${TUTORIAL}/logs/hisat2_${SAMPLE}.summary

# Sort SAM → BAM
apptainer exec --bind ${TUTORIAL},/fs/scratch/PAS3260/Jonathan ${SAM_SIF} \
    samtools sort \
        -@ 8 \
        -m 1G \
        -o ${OUTDIR}/${SAMPLE}.sorted.bam \
        ${OUTDIR}/${SAMPLE}.sam

# Index
apptainer exec --bind ${TUTORIAL},/fs/scratch/PAS3260/Jonathan ${SAM_SIF} \
    samtools index ${OUTDIR}/${SAMPLE}.sorted.bam

# Clean up intermediate SAM (large file)
rm ${OUTDIR}/${SAMPLE}.sam

echo "[$(date)] Done: ${SAMPLE}"
echo "Alignment summary for ${SAMPLE}:"
cat /fs/scratch/PAS3260/Fiona/RNAseqforteamproject/logs/hisat2_${SAMPLE}.summary
EOF

sbatch /fs/scratch/PAS3260/Fiona/RNAseqforteamproject/hisat2index/hisat2index.sh
